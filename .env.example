# Environment variables for Windows Voice-Controlled Desktop Automation Agent

# API Keys (Required for full AI/Chat functionality)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Azure Cognitive Services Speech (Recommended for Natural Voice Synthesis)
AZURE_SPEECH_KEY=YOUR_AZURE_SPEECH_KEY_HERE
AZURE_SPEECH_REGION=YOUR_AZURE_SPEECH_REGION_HERE

# ElevenLabs (Alternative for Premium Voice Synthesis)
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY_HERE
ELEVENLABS_VOICE_ID=YOUR_ELEVENLABS_VOICE_ID_HERE

# Application Configuration
LOG_LEVEL=INFO
LOG_DIR=logs
WAKE_WORD_ENABLED=true
